{
  "name": "discovery-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-rss.mjs",
    "build": "next build",
    "postbuild": "node scripts/strip-rsc-payloads.mjs && node scripts/validate-seo.mjs --warn",
    "validate:seo": "node scripts/validate-seo.mjs",
    "audit:adsense": "node scripts/validate-data.js && node scripts/audit-adsense-content.mjs --strict",
    "audit:adsense:live": "node scripts/audit-live-adsense.mjs",
    "seo:ping": "node scripts/ping-search-engines.mjs",
    "start": "next start",
    "lint": "eslint",
    "fetch-images": "tsx scripts/fetch-images.ts",
    "generate:social": "node scripts/generate-social-posts.mjs",
    "publish:social": "node scripts/publish-social-posts.mjs",
    "bulk:generate": "node scripts/bulk-generate-content.js",
    "bulk:generate:500": "node scripts/bulk-generate-content.js 500",
    "enrich": "node scripts/enrich-existing-items.js"
  },
  "dependencies": {
    "@formspree/react": "^3.0.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "@google/genai": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
