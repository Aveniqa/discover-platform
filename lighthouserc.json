{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/discover",
        "http://localhost:3000/trending",
        "http://localhost:3000/hidden-gems",
        "http://localhost:3000/future-radar",
        "http://localhost:3000/tools",
        "http://localhost:3000/categories",
        "http://localhost:3000/collections"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85, "aggregationMethod": "median" }],
        "categories:accessibility": ["error", { "minScore": 0.85, "aggregationMethod": "median" }],
        "categories:best-practices": ["warn", { "minScore": 0.85, "aggregationMethod": "median" }],
        "categories:seo": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 3000, "aggregationMethod": "median" }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000, "aggregationMethod": "median" }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.15, "aggregationMethod": "median" }],
        "total-blocking-time": ["warn", { "maxNumericValue": 500, "aggregationMethod": "median" }],
        "meta-description": "error",
        "document-title": "error",
        "canonical": "error",
        "structured-data": "warn",
        "is-crawlable": "error",
        "robots-txt": "warn"
      }
    }
  }
}
