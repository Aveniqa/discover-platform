        "categories:best-practices": ["error", { "minScore": 0.85, "aggregationMethod": "median" }],
        "categories:seo": ["error", { "minScore": 0.85, "aggregationMethod": "median" }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 3000, "aggregationMethod": "median" }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000, "aggregationMethod": "median" }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.15, "aggregationMethod": "median" }],
