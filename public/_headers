/*
  # Prevent clickjacking - only allow same-origin framing
  X-Frame-Options: SAMEORIGIN
  
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # Enable XSS protection in older browsers
  X-XSS-Protection: 1; mode=block
  
  # Strict referrer policy
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions policy - disable unused browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Content Security Policy
  # NOTE: report-uri / report-to omitted — this is a static export (Cloudflare
  # Pages, no API routes), so violation reports have no endpoint to land on.
  # Add Cloudflare Worker (or external Sentry/Report URI) and re-add directives
  # if/when reporting is needed.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://pagead2.googlesyndication.com https://*.googlesyndication.com https://www.googletagmanager.com https://fundingchoicesmessages.google.com https://*.fundingchoicesmessages.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.pexels.com https://images.unsplash.com https://*.pexels.com https://*.unsplash.com https://upload.wikimedia.org https://*.wikimedia.org https://pixabay.com https://cdn.pixabay.com https://api.microlink.io https://www.google.com https://*.google.com https://*.googlesyndication.com https://*.gstatic.com data: blob:; connect-src 'self' https://api.pexels.com https://api.unsplash.com https://pagead2.googlesyndication.com https://*.googlesyndication.com https://ep1.adtrafficquality.google https://*.adtrafficquality.google https://fundingchoicesmessages.google.com https://*.fundingchoicesmessages.google.com https://googleads.g.doubleclick.net; worker-src 'self'; frame-src 'self' https://*.pages.dev https://www.youtube-nocookie.com https://googleads.g.doubleclick.net https://fundingchoicesmessages.google.com https://*.fundingchoicesmessages.google.com; base-uri 'self'; form-action 'self'; frame-ancestors 'self'

  # Force HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# ─── Static asset caching ────────────────────────────────────

# Immutable content-hashed JS/CSS (Next.js build output) — cache forever
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Local images — cache 7 days (they don't change between builds)
/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# SVG icons/logos — cache 7 days
/*.svg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Fonts — cache 30 days (immutable between builds)
/*.woff2
  Cache-Control: public, max-age=2592000, immutable

# ─── HTML page caching (CF Pages deploy-aware) ─────────
#
# Strategy: Let CF Pages manage edge cache invalidation on deploy.
#
# CF Pages automatically invalidates its CDN cache on every deployment.
# By NOT setting a long max-age on HTML, we ensure fresh content is
# served within minutes of the daily edition push.
#
# The service worker (sw.js) handles instant loads for returning
# visitors via its own stale-while-revalidate cache. The browser
# revalidates with the edge on each navigation (cheap 304 if unchanged),
# and the SW updates its cache in the background.
#
# no-cache = always revalidate before serving (browser + CDN)
# CF edge returns 304 Not Modified via ETag if content hasn't changed,
# so revalidation is fast (~50ms RTT) and bandwidth-free.

# All HTML pages
/*.html
  Cache-Control: public, no-cache

# Category root pages (extensionless HTML on CF Pages)
/discover
  Cache-Control: public, no-cache

/hidden-gems
  Cache-Control: public, no-cache

/future-radar
  Cache-Control: public, no-cache

/tools
  Cache-Control: public, no-cache

/trending
  Cache-Control: public, no-cache

/collections
  Cache-Control: public, no-cache

/categories
  Cache-Control: public, no-cache

/about
  Cache-Control: public, no-cache

/newsletter
  Cache-Control: public, no-cache

/premium
  Cache-Control: public, no-cache

# Static info pages — cache longer (1 day), they rarely change
# These don't receive daily content updates, so a longer TTL is fine.
/privacy
  Cache-Control: public, max-age=86400

/terms
  Cache-Control: public, max-age=86400

/affiliate-disclosure
  Cache-Control: public, max-age=86400

/contact
  Cache-Control: public, max-age=86400

# Item detail pages — always revalidate (daily content may change any item)
/item/*
  Cache-Control: public, no-cache

# Collection sub-pages
/collections/*
  Cache-Control: public, no-cache

# Category sub-pages (pagination etc.)
/discover/*
  Cache-Control: public, no-cache

/hidden-gems/*
  Cache-Control: public, no-cache

/future-radar/*
  Cache-Control: public, no-cache

/tools/*
  Cache-Control: public, no-cache

/trending/*
  Cache-Control: public, no-cache

# RSC payload files — same as their HTML counterparts
/item/*.txt
  Cache-Control: public, no-cache

/collections/*.txt
  Cache-Control: public, no-cache

# ─── Service Worker ──────────────────────────────────────────

# Service worker must not be cached long — browsers check for updates
# on each navigation. max-age=0 ensures the SW update check always
# hits the network (CF edge still serves it fast via its own cache).
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# ─── Feeds and metadata ──────────────────────────────────────

# RSS feed — revalidate on each request (changes daily with new content)
/feed.xml
  Cache-Control: public, no-cache

# Sitemap — revalidate (new item pages are added daily)
/sitemap.xml
  Cache-Control: public, no-cache

# robots.txt — cache 1 day (rarely changes)
/robots.txt
  Cache-Control: public, max-age=86400
