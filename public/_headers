/*
  # Prevent clickjacking - only allow same-origin framing
  X-Frame-Options: SAMEORIGIN
  
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # Enable XSS protection in older browsers
  X-XSS-Protection: 1; mode=block
  
  # Strict referrer policy
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions policy - disable unused browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Content Security Policy with violation reporting
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.pexels.com https://images.unsplash.com data: blob:; connect-src 'self' https://api.pexels.com https://api.unsplash.com; frame-src 'self' https://*.pages.dev; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; report-uri /api/csp-report; report-to csp-endpoint
  
  # CSP Reporting endpoint (modern browsers)
  Report-To: {"group":"csp-endpoint","max_age":10886400,"endpoints":[{"url":"https://surfaced-x.pages.dev/api/csp-report"}],"include_subdomains":true}
  Reporting-Endpoints: csp-endpoint="https://surfaced-x.pages.dev/api/csp-report"
  
  # Force HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache immutable static assets aggressively (content-hashed filenames)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache local images (1 day)
/images/*
  Cache-Control: public, max-age=86400

# Cache SVGs (1 day)
/*.svg
  Cache-Control: public, max-age=86400

# HTML pages — must revalidate (content changes daily)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Subdirectory HTML pages (item detail, collections, etc.)
/item/*
  Cache-Control: public, max-age=0, must-revalidate

/collections/*
  Cache-Control: public, max-age=0, must-revalidate

# RSC payload files (.txt) — same policy as HTML
/*.txt
  Cache-Control: public, max-age=0, must-revalidate

/item/*.txt
  Cache-Control: public, max-age=0, must-revalidate

/collections/*.txt
  Cache-Control: public, max-age=0, must-revalidate

# RSS feed and sitemap (1 hour cache — regenerated each build)
/feed.xml
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600
